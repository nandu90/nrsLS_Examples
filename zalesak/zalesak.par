[GENERAL]
polynomialOrder = 7
stopAt = endTime
endTime = 2.0
dt = 1e-4
timeStepper = tombo2

checkPointControl = simulationTime 
checkPointInterval = 0.2

scalars = s00

[FLUID VELOCITY]
solver = none
boundaryTypeMap = O
residualTol = 1e-06
density = 1.0
viscosity = 1e-10 

[SCALAR S00]
boundaryTypeMap = t
transportCoeff = 1.0
diffusionCoeff = 1e-10
residualTol = 1e-08
regularization = svv+svvCoeff=1.0+filterPower=2.0


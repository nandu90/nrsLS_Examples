[OCCA]
  backend = CUDA

[GENERAL]
polynomialOrder = 5
stopAt = numSteps
numSteps = 0
dt = 4e-3
timeStepper = tombo2

checkPointInterval = 200

scalars = phi

[FLUID VELOCITY]
solver = none

[SCALAR PHI]
transportCoeff = 1.0
diffusionCoeff = 1e-14
residualTol = 1e-08
regularization = svv+scalingCoeff=2.0+filterPower=6.0
